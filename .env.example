# ============================================================
#  Variables de entorno (SOLO servidor) - copiar a .env.local
# ============================================================

# API key de Groq. Obtenela en: https://console.groq.com/keys
# IMPORTANTE: nunca se expone al navegador, solo la usan los Route Handlers.
GROQ_API_KEY=tu_api_key_de_groq_aca

# (Opcional) Modelo a usar. Por defecto: llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
